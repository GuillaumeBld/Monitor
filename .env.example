# === Finnhub (primary data source) ===
FINNHUB_API_KEY=your_finnhub_api_key

# === Upstash Redis (caching + alert dedup) ===
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# === Slack notifications (optional) ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# === Telegram notifications (optional) ===
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# === Alert security ===
ALERT_SECRET=generate_with_openssl_rand_hex_32
NEXT_PUBLIC_ALERT_SECRET=same_value_as_ALERT_SECRET

# === Vercel Cron (auto-set on newer Vercel projects) ===
CRON_SECRET=auto_or_generate_random
